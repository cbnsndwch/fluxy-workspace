{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "singleQuote": true,
    "bracketSpacing": true,
    "trailingComma": "none",
    "printWidth": 80,
    "tabWidth": 4,
    "useTabs": false,
    "endOfLine": "lf",
    "semi": true,
    "arrowParens": "avoid",
    "overrides": [
        {
            "files": [
                "*.puml",
                "*.yml"
            ],
            "options": {
                "tabWidth": 2
            }
        }
    ],
    "ignorePatterns": [
        ".editorconfig",
        ".gitignore",
        ".turbo",
        ".vscode",
        "assets",
        "build",
        "dist",
        "docs",
        "node_modules"
    ],
    "sortImports": {
        "customGroups": [
            {
                "groupName": "app-internal",
                "elementNamePattern": [
                    "@/**"
                ]
            }
        ],
        "groups": [
            [
                "value-builtin",
                "value-external"
            ],
            "app-internal",
            [
                "value-parent",
                "value-sibling",
                "value-index"
            ],
            "unknown"
        ]
    }
}