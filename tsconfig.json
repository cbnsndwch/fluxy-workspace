{
    "compilerOptions": {
        "target": "ES2023",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "rootDir": ".",
        "jsx": "react-jsx",
        "types": [],
        "paths": {
            "@/*": ["./client/src/*"]
        }
    },
    "include": [
        "client/src",
        "backend",
    ],
    "exclude": ["node_modules", "dist", "data"]
}
